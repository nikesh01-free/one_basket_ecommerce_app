# ─────────────────────────────────────────────────────────────────────────────
# OneBasket – Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the real values below.
# 3. NEVER commit .env to git – it is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys  (use test keys for dev)
STRIPE_PUBLISHABLE_KEY=pk_test_<your-stripe-publishable-key>

# ── Hyperlocal Config ─────────────────────────────────────────────────────────
DELIVERY_CITY=Ahmedabad
DELIVERY_RADIUS_KM=15.0
MIN_ORDER_AMOUNT=150.00
FLAT_DELIVERY_CHARGE=30.00

# ── Support / Contact ─────────────────────────────────────────────────────────
SUPPORT_PHONE=+91XXXXXXXXXX
SUPPORT_EMAIL=support@yourapp.in
